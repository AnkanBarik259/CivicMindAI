# .env.example

# --- PUBLIC FRONTEND VARIABLES ---
# These are safe to expose to the browser (Firebase Client SDK)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# --- PRIVATE BACKEND SECRETS ---
# NEVER expose these to the frontend (Do not prefix with VITE_)
# Generate secure random strings for secrets: `openssl rand -hex 32`
GEMINI_API_KEY=""

FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_PRIVATE_KEY=""
FIREBASE_ADMIN_CLIENT_EMAIL=""

# Cloudinary Configurations
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Lifecycle configurations
TEMPORARY_ISSUE_EXPIRY_SECONDS=900

